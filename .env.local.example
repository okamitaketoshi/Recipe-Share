# ローカルDB用環境変数（Supabase CLI使用）
# 使用方法: このファイルを .env.local にコピーしてローカルDB環境を有効化
#   cp .env.local.example .env.local

# Supabase CLIローカル環境のエンドポイント
# npx supabase start で起動すると http://localhost:54321 でアクセス可能
VITE_SUPABASE_URL=http://localhost:54321

# Supabase CLIのデフォルトanon key（ローカル開発用）
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# PostgreSQL接続文字列（ローカル開発用、必要に応じて使用）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
